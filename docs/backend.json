
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "بيانات المستخدم وصلاحياته",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["customer", "staff", "admin"] },
        "displayName": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "أصناف قائمة الطعام",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "طلبات العملاء",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "customerUid": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhoneNumber": { "type": "string" },
        "carLicensePlate": { "type": "string" },
        "carType": { "type": "string" },
        "items": { "type": "array" },
        "totalPrice": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "preparing", "ready", "completed"] },
        "createdAt": { "type": "number" },
        "specialRequests": { "type": "string" },
        "createdBy": { "type": "string", "description": "ID of the staff who created it manually" }
      }
    },
    "AppConfig": {
      "title": "AppConfig",
      "description": "إعدادات التطبيق العامة",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" },
        "updatedAt": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "ملفات المستخدمين"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "أصناف المنيو"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "طلبات الطعام"
    },
    "/settings/{settingId}": {
      "schema": "AppConfig",
      "description": "إعدادات التطبيق"
    }
  }
}
