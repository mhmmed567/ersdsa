
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // قواعد ملفات المستخدمين
    match /users/{userId} {
      // السماح لأي مستخدم مسجل بقراءة ملفه الشخصي
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // السماح للمسؤولين بقراءة ملفات المستخدمين للتحقق من الأدوار
      allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
      
      // السماح للمستخدم بإنشاء وتحديث ملفه الخاص (مهم جداً عند التسجيل لأول مرة)
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // قواعد الطلبات
    match /orders/{orderId} {
      // السماح للجميع بإنشاء طلبات
      allow create: if true;
      
      // السماح للمسؤولين فقط بقراءة وتحديث حالة الطلبات
      allow read, update: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
      
      allow delete: if false;
    }
  }
}
