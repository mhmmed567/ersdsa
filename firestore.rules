
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظيفة للتحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // وظيفة للتحقق مما إذا كان المستخدم يملك رتبة مسؤول (Staff)
    function isStaff() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
    }

    // قواعد المستخدمين: كل مستخدم يصل لملفه فقط، والمسؤول يرى الجميع
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read: if isStaff();
    }

    // قواعد المنتجات (المنيو): الجميع يقرأ، والمسؤول فقط يعدل
    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // قواعد الطلبات: الجميع ينشئ طلبات، والمسؤول فقط يراها ويديرها
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }
  }
}
