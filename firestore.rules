
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // قواعد ملفات المستخدمين
    match /users/{userId} {
      // السماح للمستخدم المسجل بقراءة ملفه الخاص
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // السماح للموظفين بقراءة ملفات المستخدمين الآخرين للتحقق من الصلاحيات
      allow read: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
      
      // السماح للمستخدم بإنشاء ملفه الشخصي وتحديثه
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // قواعد الطلبات
    match /orders/{orderId} {
      // السماح لأي شخص بإنشاء طلب (للزبائن والضيوف)
      allow create: if true;
      
      // السماح للمسؤولين فقط بقراءة وتحديث الطلبات
      allow read, update: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
      
      allow delete: if false;
    }
  }
}
