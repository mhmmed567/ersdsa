
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظيفة للتحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // وظيفة جلب بيانات المستخدم الحالي
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // وظيفة للتحقق من صلاحية المسؤول
    function isStaff() {
      return isSignedIn() && (
        getUserData().role == 'staff' || 
        // السماح بإنشاء الملف الشخصي أول مرة
        request.resource.data.role == 'staff'
      );
    }

    // قواعد المستخدمين
    match /users/{userId} {
      // السماح للمستخدم بقراءة وكتابة ملفه الخاص دائماً
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      // السماح للمسؤولين بقراءة بيانات المستخدمين (لإدارة الطلبات مثلاً)
      allow read: if isSignedIn() && (request.auth.uid == userId || getUserData().role == 'staff');
    }

    // قواعد المنتجات (المنيو)
    match /products/{productId} {
      allow read: if true; // الجميع يقرأ المنيو
      allow write: if isSignedIn() && getUserData().role == 'staff';
    }

    // قواعد الطلبات
    match /orders/{orderId} {
      allow create: if true; // الزبائن ينشئون طلبات
      allow read, update, delete: if isSignedIn() && getUserData().role == 'staff';
    }
  }
}
