
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // وظيفة للتحقق من تسجيل الدخول
    function isSignedIn() {
      return request.auth != null;
    }

    // وظيفة للتحقق مما إذا كان المستخدم يملك رتبة مسؤول
    function isStaff() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff';
    }

    // قواعد المستخدمين
    match /users/{userId} {
      // يسمح للمستخدم بقراءة وكتابة ملفه الخاص
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      // يسمح للمسؤولين بقراءة بيانات أي مستخدم
      allow read: if isSignedIn() && (request.auth.uid == userId || isStaff());
    }

    // قواعد المنتجات (المنيو)
    match /products/{productId} {
      allow read: if true; // الجميع يقرأ المنيو
      allow write: if isStaff(); // المسؤولون فقط يعدلون المنيو
    }

    // قواعد الطلبات
    match /orders/{orderId} {
      allow create: if true; // السماح بإنشاء طلبات (حتى للضيوف)
      allow read, update, delete: if isStaff(); // المسؤولون فقط يديرون الطلبات
    }
  }
}
